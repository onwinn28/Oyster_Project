#### 7. Statistical Testing: Wilcoxon Date Comparison ####

Corrected_dates <- Shell_Bags %>%
  mutate(
    Clean_Date = ifelse(is.na(`Date processed`), `Date collected?`, `Date processed`),
    Year       = year(mdy(Clean_Date))
  ) %>%
  filter(!is.na(Year), !is.na(total_spat))

# Filter down to compare two specific autumn dates
compare_data <- Corrected_dates %>%
  filter(`Date collected?` %in= c("10/2/24", "9/19/24"))

compare_data %>%
  group_by(`Date collected?`) %>%
  summarise(
    Avg_Spat = mean(spat_alive, na.rm = TRUE),
    Sample_Size = n(),
    .groups = "drop"
  )

# Non-parametric assessment of live spat counts between these dates
wilcox.test(spat_alive ~ `Date collected?`, data = compare_data)


#### 8. Statistical Testing: Global Kruskal-Wallis & Boxplot ####

df_clean <- Shell_Bags %>%
  filter(!is.na(`Date collected?`), !is.na(spat_alive)) %>%
  mutate(Date_Parsed = lubridate::mdy(`Date collected?`)) %>%
  filter(lubridate::year(Date_Parsed) == 2024)

# Calculate overall significance value across all collection dates
global_p <- kruskal.test(spat_alive ~ Date_Parsed, data = df_clean)$p.value

# Plot: Boxplot distribution of live spat counts by collection date
ggplot(df_clean, aes(x = Date_Parsed, y = spat_alive, group = Date_Parsed)) +
  geom_boxplot(aes(fill = as.factor(`Date collected?`)), alpha = 0.6, outlier.shape = NA) +
  geom_jitter(width = 0.5, alpha = .5, color = "black") +
  scale_x_date(date_labels = "%m/%d/%y", date_breaks = "1 week") +
  labs(
    title = "Spat Distribution Over Time",
    subtitle = paste0("Global Kruskal-Wallis p-value: ", round(global_p, 5)),
    x = "Date Collected (Chronological)",
    y = "Live Spat Count",
    fill = "Date"
  ) +
  theme_evan +
  theme(
    axis.text.x = element_text(angle = 45, hjust = 1),
    legend.position = "none"
  )


#### 9. Post-Hoc Pairwise Testing & Heatmap ####

# Run pairwise Wilcoxon tests with Holm corrections
pairwise_results <- pairwise.wilcox.test(
  x = df_clean$spat_alive, 
  g = df_clean$`Date collected?`, 
  p.adjust.method = "holm"
)

# Extract significance matrix safely
p_matrix <- pairwise_results$p.value

# Reshape the triangular matrix into long form for plotting
p_df <- as.data.frame(p_matrix) %>%
  rownames_to_column(var = "Date1") %>%
  pivot_longer(-Date1, names_to = "Date2", values_to = "p_value") %>%
  filter(!is.na(p_value))

# Plot: Pairwise significance heatmap
ggplot(p_df, aes(x = Date1, y = Date2, fill = p_value)) +
  geom_tile(color = "white", lwd = 0.5) +
  scale_fill_gradient2(low = "#d7191c", mid = "#ffffbf", high = "#2c7bb6", 
                       midpoint = 0.05, name = "p-value") +
  geom_text(aes(label = sprintf("%.3f", p_value)), color = "black", size = 3) +
  labs(title = "Pairwise Significance Matrix",
       subtitle = "Red boxes indicate significant differences (p < 0.05)",
       x = "", y = "") +
  theme_minimal() +
  theme(axis.text.x = element_text(angle = 45, hjust = 1))

#### 10. Cumulative Settlement and Spat Survival ####
library(ggplot2)
library(dplyr)
library(tidyr)
library(lubridate)
library(janitor)

# 1. Clean and prepare the sequential deployment data
survival_cumulative <- Shell_Bags %>%
  # Clean names to automatically handle trailing spaces in column headers
  clean_names() %>% 
  mutate(
    Date_Collected = mdy(date_collected),
    Year           = year(Date_Collected)
  ) %>%
  # Focus on the 2024 season
  filter(Year == 2024, !is.na(Date_Collected)) %>%
  group_by(Date_Collected) %>%
  summarise(
    # "Live Spat" is the active living cohort found at retrieval
    Active_Live = mean(spat_alive, na.rm = TRUE),
    # "Dead Spat" is the accumulated mortality since deployment
    Accumulated_Dead = mean(spat_dead, na.rm = TRUE),
    .groups = "drop"
  ) %>%
  # Reshape for ggplot
  pivot_longer(
    cols = c(Active_Live, Accumulated_Dead), 
    names_to = "Cohort_Status", 
    values_to = "Avg_Spat"
  ) %>%
  # Make factor levels intuitive for the stacked legend
  mutate(Cohort_Status = factor(
    Cohort_Status, 
    levels = c("Accumulated_Dead", "Active_Live"),
    labels = c("Accumulated Dead (Mortality)", "Active Live Spat (Standing Crop)")
  ))

# 2. Plot cumulative history of the shell bags
ggplot(survival_cumulative, aes(x = Date_Collected, y = Avg_Spat, fill = Cohort_Status)) +
  # Stacked columns show the total cumulative settlement over time
  geom_col(position = "stack", width = 6, color = "white", size = 0.2) +
  scale_fill_manual(values = c(
    "Accumulated Dead (Mortality)" = "#e57373",      # Soft red for accumulated losses
    "Active Live Spat (Standing Crop)" = "#4fc3f7"  # Soft blue for current survivors
  )) +
  scale_x_date(date_breaks = "2 weeks", date_labels = "%b %d") +
  theme_evan + # Uses your custom light theme
  labs(
    title = "Cumulative Larval Settlement & Standing Live Spat (Basin 2024)",
    subtitle = "Total height of bars shows total settlement over time; dead spat represents accumulated mortality.",
    x = "Retrieval Date (Bags accumulated spat since start of season)",
    y = "Average Spat per Bag",
    fill = "Spat Status"
  ) +
  theme(
    plot.title = element_text(face = "bold", size = 11),
    axis.text.x = element_text(angle = 45, hjust = 1),
    legend.position = "bottom",
    legend.direction = "vertical"
  )

