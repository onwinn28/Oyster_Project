library(dplyr)
library(lubridate)
library(janitor)
library(ggplot2)

anova_df <- Shell_Bags %>%
  clean_names() %>%
  mutate(
    Date_Parsed = mdy(date_collected),
    Year = year(Date_Parsed),
    Zone = tools::toTitleCase(tolower(zone_low_mid_high))
  ) %>%
  # Filter for valid 2024 records with recorded spat values
  filter(Year == 2024, !is.na(Zone), !is.na(total_spat)) %>%
  mutate(Zone = factor(Zone, levels = c("Low", "Mid", "High")))

anova_bags <- aov(total_spat ~ Zone, data = anova_df)

summary(anova_bags)

TukeyHSD(anova_bags)

anova_sqrt <- aov(sqrt(total_spat) ~ Zone, data = anova_df)

plot(anova_sqrt, which = 2)
plot(anova_sqrt, which = 1)

