#### 10. Ecological Association: Barnacle Co-occurrence ####

# Clean names for programmatic clarity
data <- X2026_analysis_Shoreline_Survey_Data_Cleaned_Data_2 %>%
  clean_names()

# Isolate co-occurrence frequencies
total_oysters <- sum(data$american_osyter_1_0 == 1, na.rm = TRUE)
total_barnacles <- sum(data$acorn_barnacles == 1, na.rm = TRUE)
both_present <- sum(data$american_osyter_1_0 == 1 & data$acorn_barnacles == 1, na.rm = TRUE)

# Calculate Conditional Probabilities
prob_barnacle_given_oyster <- both_present / total_oysters
prob_oyster_given_barnacle <- both_present / total_barnacles

cat("1. If you find an oyster, the probability you find a barnacle is:", 
    round(prob_barnacle_given_oyster * 100, 2), "%\n")
cat("2. If you find a barnacle, the probability you find an oyster is:", 
    round(prob_oyster_given_barnacle * 100, 2), "%\n")

# Statistical testing of proportions
test_result <- prop.test(c(both_present, both_present), c(total_oysters, total_barnacles))
print(test_result)


#### 11. Ecological Association: Habitat Suitability Analysis ####

# Load fresh copy of data
data <- read_csv("~/Downloads/2026-analysis_Shoreline Survey Data - Cleaned Data-2.csv")

# Define classifications of substrates
suitable_cols <- c(
  "Cobble", 
  "Small Boulder", 
  "Medium Boulder", 
  "Large Boulder", 
  "Boulder of unspecified size", 
  "Bedrock/Ledge"
)

unsuitable_cols <- c(
  "Mud", 
  "Sand", 
  "Gravel", 
  "Pebble", 
  "Shell", 
  "Leaf Liter", 
  "Unspecified movable rock"
)

# Classify each quadrat row based on substrate suitability presence
has_suitable <- rowSums(data[, suitable_cols] == 1, na.rm = TRUE) > 0
has_unsuitable <- rowSums(data[, unsuitable_cols] == 1, na.rm = TRUE) > 0

habitat_data <- data.frame(
  Oyster_Present = data$`American Osyter (1/0)` == 1,
  Has_Suitable = has_suitable,
  Has_Ununsuitable = has_unsuitable
)

# Assign habitat categorical hierarchy (Suitable overrides Unsuitable)
habitat_data$Habitat_Type <- "Neither"
habitat_data$Habitat_Type[habitat_data$Has_Ununsuitable] <- "Unsuitable"
habitat_data$Habitat_Type[habitat_data$Has_Suitable] <- "Suitable"

# Remove unclassified records
habitat_filtered <- subset(habitat_data, Habitat_Type != "Neither")

# Compute cross-tabulation table
summary_table <- table(habitat_filtered$Habitat_Type, habitat_filtered$Oyster_Present)
colnames(summary_table) <- c("Oyster Absent", "Oyster Present")
pct_table <- prop.table(summary_table, margin = 1) * 100

# Display results
cat("=== Number of Quadrats in each Habitat ===\n")
print(summary_table)
cat("\n=== Percentage of Oyster Presence by Habitat Type ===\n")
print(round(pct_table, 2))

# Chi-Square Test of Association
chisq_result <- chisq.test(summary_table)
cat("\n=== Chi-Square Test of Association ===\n")
print(chisq_result)


#### 12. Mapping Suitability & Oyster Occupancy (Leaflet) ####

# Re-define suitable and unsuitable lists for the local environment
suitable_cols <- c("Cobble", "Small Boulder", "Medium Boulder", "Large Boulder", "Boulder of unspecified size", "Bedrock/Ledge")
unsuitable_cols <- c("Mud", "Sand", "Gravel", "Pebble", "Shell", "Leaf Liter", "Unspecified movable rock")

# Construct spatial coordinates mapping with parsed habitat classifications
map_habitat_data <- clean_oysters_coordinates %>%
  mutate(
    Year = year(mdy(Date)),
    Lat_num = as.numeric(Latitude),
    Lon_num = as.numeric(Longitude)
  ) %>%
  mutate(
    Correct_Lat = ifelse(!is.na(Lat_num) & Lat_num < 0, Lon_num, Lat_num),
    Correct_Lon = ifelse(!is.na(Lat_num) & Lat_num < 0, Lat_num, Lon_num)
  ) %>%
  filter(!is.na(Correct_Lat), !is.na(Correct_Lon), Year != 2027) %>%
  mutate(
    Has_Suitable = rowSums(.[, suitable_cols] == 1, na.rm = TRUE) > 0,
    Has_Unsuitable = rowSums(.[, unsuitable_cols] == 1, na.rm = TRUE) > 0,
    Habitat_Type = case_when(
      Has_Suitable ~ "Suitable",
      Has_Unsuitable ~ "Unsuitable", 
      TRUE ~ "Neither"
    )
  ) %>%
  filter(Habitat_Type != "Neither") %>%
  mutate(
    Oyster_Presence = ifelse(`American Osyter (1/0)` == 1, "Oysters Present", "Oysters Absent"),
    Map_Status = paste(Habitat_Type, "-", Oyster_Presence)
  )

# Palette creation for the 4 suitability-presence statuses
status_colors <- colorFactor(
  palette = c(
    "Suitable - Oysters Present"   = "#98df8a",
    "Suitable - Oysters Absent"    = "#2ca02c",
    "Unsuitable - Oysters Present" = "#ff9896",
    "Unsuitable - Oysters Absent"  = "#d62728"
  ), 
  domain = map_habitat_data$Map_Status
)

# Spatial rendering
leaflet(map_habitat_data) %>%
  addProviderTiles(providers$Esri.WorldImagery) %>% 
  addCircleMarkers(
    lng = ~Correct_Lon, 
    lat = ~Correct_Lat, 
    color = ~status_colors(Map_Status),
    radius = 1.5, 
    stroke = TRUE,
    weight = 1,
    fillColor = ~status_colors(Map_Status),
    fillOpacity = 0.9,
    popup = ~paste(
      "<b>Site:</b>", Site, "<br>",
      "<b>Habitat:</b>", Habitat_Type, "<br>",
      "<b>Oysters:</b>", Oyster_Presence, "<br>",
      "<b>Year:</b>", Year
    )
  ) %>%
  addLegend(
    pal = status_colors, 
    values = ~Map_Status, 
    title = "Habitat & Oyster Status", 
    position = "bottomright"
  )


