#### 4. Spatial Data Preparation & Geographic Distance ####

library(geosphere)

# Filter for coordinate-bearing rows and clean outliers
clean_oysters_coordinates <- Clean_data %>%
  filter(!is.na(Latitude)) %>%
  filter(!`Unique Quad (#)` %in% c("DM-26-M-1", "DR-23-L-23"))

# Correct coordinate orientations (fixing negative latitude flips)
cleaned_data <- clean_oysters_coordinates %>%
  mutate(
    Year = year(mdy(Date)),
    Lat_num = as.numeric(Latitude),
    Lon_num = as.numeric(Longitude)
  ) %>%
  mutate(
    Correct_Lat = ifelse(!is.na(Lat_num) & Lat_num < 0, Lon_num, Lat_num),
    Correct_Lon = ifelse(!is.na(Lat_num) & Lat_num < 0, Lat_num, Lon_num)
  ) %>%
  filter(!is.na(Correct_Lat), !is.na(Correct_Lon), Year != 2027)

# Calculate shoreline distances (meters and miles) between consecutive quadrats
shoreline_distances <- cleaned_data %>%
  arrange(Site, Year, `Zone (mid, low)`, `Quad (#)`) %>%
  group_by(Site, Year) %>%
  mutate(
    dist_from_prev = distHaversine(
      cbind(lag(Correct_Lon), lag(Correct_Lat)), 
      cbind(Correct_Lon, Correct_Lat)
    )
  ) %>%
  summarise(
    Total_Distance_Meters = sum(dist_from_prev, na.rm = TRUE),
    Total_Distance_Miles = Total_Distance_Meters * 0.000621371,
    Total_Quadrats = n(),
    .groups = "drop"
  )

print(shoreline_distances)


#### 5. Interactive Mapping (Leaflet) ####

library(leaflet)

# Prepare mapping specific dataset
map_data <- clean_oysters_coordinates %>%
  mutate(
    Year = year(mdy(Date)),
    Lat_num = as.numeric(Latitude),
    Lon_num = as.numeric(Longitude)
  ) %>%
  mutate(
    Correct_Lat = ifelse(!is.na(Lat_num) & Lat_num < 0, Lon_num, Lat_num),
    Correct_Lon = ifelse(!is.na(Lat_num) & Lat_num < 0, Lat_num, Lon_num)
  ) %>%
  filter(!is.na(Correct_Lat), !is.na(Correct_Lon), Year != 2027)

# Set up color coding for each survey year
year_colors <- colorFactor(palette = "viridis", domain = map_data$Year)

# Generate Leaflet Interactive Map with Satellite Imagery
leaflet(map_data) %>%
  addProviderTiles(providers$Esri.WorldImagery) %>% 
  addCircleMarkers(
    lng = ~Correct_Lon, 
    lat = ~Correct_Lat, 
    color = ~year_colors(Year),
    radius = 4, 
    stroke = FALSE, 
    fillOpacity = 0.8,
    popup = ~paste("Site:", Site, "<br>Year:", Year)
  ) %>%
  addLegend(
    pal = year_colors, 
    values = ~Year, 
    title = "Year Surveyed", 
    position = "bottomright"
  )


